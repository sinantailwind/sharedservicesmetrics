# PostgreSQL connection string
# Railway provides this automatically if you attach a Postgres service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Aircall API credentials (from Aircall dashboard → Integrations → API Keys)
# Leave blank to run without Aircall — the dashboard will show a "Connect Aircall" prompt
AIRCALL_API_ID=
AIRCALL_API_TOKEN=

# Optional: app port (Railway sets this automatically)
PORT=3000
